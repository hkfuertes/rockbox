#!/system/bin/sh
# Innioasis Y1 script
# Functionality:
# 1. Forces a restart of Rockbox when the combination (previous track + next track / LEFT + RIGHT) 
#    is held for 5 seconds.
#    Note: For reliable detection, press LEFT first, then RIGHT immediately, and hold both for 5 seconds.
#    Pressing both very quickly at the same time may miss events and fail to trigger the restart.
# 2. Trigger Keyboard when Play/Pause is pressed in a text input prompt

DEVICE="/dev/input/event2"
MAX_HOLD=5  # seconds to trigger restart

# Exit if the input device is not found
if [ ! -e "$DEVICE" ]; then
    exit 1
fi

# Function to reverse byte order (little-endian to big-endian)
reverse_bytes() {
    hex="$1"
    echo "$hex" | sed 's/../& /g' | awk '{for(i=NF;i>0;i--)printf $i; print ""}'
}

left_down=0
right_down=0
press_start_sec=0

# Function to restart Rockbox
restart_rockbox() {
    am force-stop org.rockbox
    am start -n org.rockbox/.RockboxActivity
}

# Main loop: read raw input events
while true; do
    event_bytes=$(dd if="$DEVICE" bs=16 count=1 2>/dev/null | xxd -p)
    [ -z "$event_bytes" ] && break

    # Extract timestamp (seconds only)
    sec_hex=$(reverse_bytes ${event_bytes:0:8})
    sec=$((0x$sec_hex))

    # Extract event type, code, and value
    type_hex=$(reverse_bytes ${event_bytes:16:4})
    value_hex=$(reverse_bytes ${event_bytes:24:8})
    code_hex=$(reverse_bytes ${event_bytes:20:4})

    type=$((0x$type_hex))
    value=$((0x$value_hex))
    code=$((0x$code_hex))

    # Only process key events
    if [ "$type" -eq 1 ]; then
        case "$code" in
            164) # (play/pause button triggers keyboard in text fields)
                input trackball press
                ;;
            105) # KEY_LEFT / previous track
                left_down=$value
                ;;
            106) # KEY_RIGHT / next track
                right_down=$value
                ;;
        esac

        # Record start of the combination
        if [ "$left_down" -eq 1 ] && [ "$right_down" -eq 1 ] && [ "$press_start_sec" -eq 0 ]; then
            press_start_sec=$sec
        fi

        # Check if either key is released
        if [ "$press_start_sec" -ne 0 ] && { [ "$left_down" -eq 0 ] || [ "$right_down" -eq 0 ]; }; then
            hold_time=$((sec - press_start_sec))
            if [ "$hold_time" -ge "$MAX_HOLD" ]; then
                restart_rockbox
            fi
            press_start_sec=0
        fi
    fi
done
