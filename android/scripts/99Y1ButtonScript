#!/system/bin/sh
# Innioasis Y1 script
# Functionality:
# 1. Forces a restart of Rockbox when the combination (previous track + next track / LEFT + RIGHT) 
#    is held for 5 seconds.
#    Note: For reliable detection, press LEFT first, then RIGHT immediately, and hold both for 5 seconds.
#    Pressing both very quickly at the same time may miss events and fail to trigger the restart.
# 2. Trigger Keyboard when Play/Pause is pressed 3x in a text input prompt
# 3. Switch to Rockbox when Back + Play are pressed for 10 seconds in Stock app.
# 4. Initial setup of apps and settings on first boot

# wait for boot completion before proceeding
BOOT_COMPLETED=0
while [ "$BOOT_COMPLETED" -ne 1 ]; do
    BOOT_COMPLETED=$(getprop sys.boot_completed)
    sleep 1
done
# make button presses silent
settings put system sound_effects_enabled 0

# setup apps on first boot
if [ ! -f /data/data/initialized ]; then
    pm install /data/data/com.innioasis.y1.apk
    pm disable com.innioasis.y1
    pm install /data/data/LeanKeyKeyboardPro_v5.2.15_r.apk
    ime enable org.liskovsoft.androidtv.rukeyboard/com.liskovsoft.leankeyboard.keyboard.leanback.ime.LeanbackImeService
    ime set org.liskovsoft.androidtv.rukeyboard/com.liskovsoft.leankeyboard.keyboard.leanback.ime.LeanbackImeService
    touch /data/data/initialized
fi

DEVICE="/dev/input/event2"
MAX_HOLD=5  # seconds to trigger restart
MAX_HOLD_DUAL_BOOT=10

# Exit if the input device is not found
if [ ! -e "$DEVICE" ]; then
    exit 1
fi

# Function to reverse byte order (little-endian to big-endian)
reverse_bytes() {
    hex="$1"
    echo "$hex" | sed 's/../& /g' | awk '{for(i=NF;i>0;i--)printf $i; print ""}'
}

left_down=0
right_down=0
menu_down=0
play_down=0
press_start_sec=0
press_start_sec_dual_boot=0
press_start_sec_media_stop=0
press_last_sec_media_stop=0

package_rb="org.rockbox"

# Function to restart Rockbox
restart_rockbox() {
    am force-stop org.rockbox
    am start -n org.rockbox/.RockboxActivity
}

dual_boot() {
    keymap_rb="/system/usr/keylayout/Rockbox.kl"
    keymap="/system/usr/keylayout/Generic.kl"

    # Check if Rockbox is disabled
    if pm list packages -d | grep -q "$package_rb"; then
        # Rockbox is disabled
        echo "Package $package_rb is disabled."
        echo "Setting up Rockbox Keymap."
        mount -o remount,rw /system
        cp "$keymap_rb" "$keymap"
        echo "Enabling Rockbox"
        pm enable org.rockbox
        echo "Disabling Stock"
        pm disable com.innioasis.y1
        echo "Rebooting"
        reboot
    fi
}

# Main loop: read raw input events
while true; do
    # Only check buttons if the screen is on
    if dumpsys power | grep -q "mScreenOn=true"; then
        event_bytes=$(dd if="$DEVICE" bs=16 count=1 2>/dev/null | xxd -p)
        [ -z "$event_bytes" ] && break

        # Extract timestamp (seconds only)
        sec_hex=$(reverse_bytes ${event_bytes:0:8})
        sec=$((0x$sec_hex))

        # Extract event type, code, and value
        type_hex=$(reverse_bytes ${event_bytes:16:4})
        value_hex=$(reverse_bytes ${event_bytes:24:8})
        code_hex=$(reverse_bytes ${event_bytes:20:4})

        type=$((0x$type_hex))
        value=$((0x$value_hex))
        code=$((0x$code_hex))

        # Only process key events
        if [ "$type" -eq 1 ]; then
            echo $code
            case "$code" in
                164) # Play/Pause
                    play_down=$value
                    # reset other keys, combination is interrupted
                    left_down=0
                    right_down=0
                    ;;
                158) # Back/Menu
                    menu_down=$value
                    # reset other keys, combination is interrupted
                    left_down=0
                    right_down=0
                    ;;
                105) # KEY_LEFT / previous track
                    left_down=$value
                    # reset other keys, combination is interrupted
                    play_down=0
                    menu_down=0
                    ;;
                106) # KEY_RIGHT / next track
                    right_down=$value
                    # reset other keys, combination is interrupted
                    play_down=0
                    menu_down=0
                    ;;
            *) # reset keys if any other is pressed
                    play_down=0
                    menu_down=0
                    left_down=0
                    right_down=0
            esac

            # Record start of the combination
            if [ "$left_down" -eq 1 ] && [ "$right_down" -eq 1 ] && [ "$press_start_sec" -eq 0 ]; then
                press_start_sec=$sec
            fi

            if [ "$menu_down" -eq 1 ] && [ "$play_down" -eq 1 ] && [ "$press_start_sec_dual_boot" -eq 0 ]; then
                press_start_sec_dual_boot=$sec
            fi

            # Check if either key is released (left/right)
            if [ "$press_start_sec" -ne 0 ]; then
                if [ "$left_down" -eq 0 ] || [ "$right_down" -eq 0 ]; then
                    hold_time=$((sec - press_start_sec))
                    if [ "$hold_time" -ge "$MAX_HOLD" ] && pm list packages -e | grep -q "$package_rb"; then
                        restart_rockbox
                    fi
                    press_start_sec=0
                fi
            fi
            # Check if either key is released (menu/play)
            if [ "$press_start_sec_dual_boot" -ne 0 ]; then
                if [ "$menu_down" -eq 0 ] || [ "$play_down" -eq 0 ]; then
                    hold_time=$((sec - press_start_sec_dual_boot))
                    if [ "$hold_time" -ge "$MAX_HOLD_DUAL_BOOT" ]; then
                        dual_boot
                    fi
                    press_start_sec_dual_boot=0
                fi
            fi
        fi
    fi
done
